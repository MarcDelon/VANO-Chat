  h2 { color: #0095f6; font-size: 19pt; margin-top: 40px; border-bottom: 2px solid #0095f6; padding-bottom: 5px; background: #f0f7ff; padding: 10px; }
  h3 { color: #2c3e50; font-size: 15pt; margin-top: 25px; font-weight: bold; background-color: #f8f9fa; padding: 10px; border-radius: 5px; border-left: 5px solid #0095f6; }
  p, li { margin-bottom: 15px; text-align: justify; }
  .code-block { background-color: #f4f4f4; border-left: 5px solid #d63384; padding: 20px; font-family: 'Consolas', 'Courier New', monospace; font-size: 10pt; color: #2c3e50; margin: 20px 0; white-space: pre-wrap; }
  .explanation { background-color: #fff9db; padding: 20px; border-radius: 10px; margin: 15px 0; border: 1px solid #ffe066; font-size: 10pt; }
